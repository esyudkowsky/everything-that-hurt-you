# Dependencies (dev-only; used for the test harness / tooling)
node_modules/

# OS / editor cruft
.DS_Store
*.swp
Thumbs.db

# Local env / secrets — never commit these
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.pyc

# Local build / temp
*.log

# Media pipeline output — hashed media is uploaded to R2, never committed.
# (assets/manifest.prod.json IS committed: Vercel serves it. See build_media.js.)
/dist-media/

# Local QA reroll candidates & rejects (chosen versions are promoted into assets/)
claude-notes/qa/rerolls/
.secrets/
.vercel
.env*
